# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_DAILY_LIMIT=900

# Google AdSense
GOOGLE_ADS_CLIENT=ca-pub-XXXXXXXXXX
GOOGLE_ADS_SLOT_SIDEBAR=1234567890
GOOGLE_ADS_SLOT_SPLASH=0987654321

# Session secret (generate with: openssl rand -base64 48)
SESSION_SECRET=change-me

# Server
PORT=1978
BASE_URL=https://maps.djooga.com
